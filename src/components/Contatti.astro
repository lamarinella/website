</section>

<style>
  .contatti {
    background: var(--color-background);
  }

  .section-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto var(--spacing-xl);
  }

  .section-header h2 {
    margin-bottom: var(--spacing-md);
  }

  .section-subtitle {
    color: rgba(12, 12, 12, 0.6);
    line-height: 1.8;
  }

  .contatti-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xl);
    align-items: start;
  }

  .contatti-info {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .info-card {
    display: flex;
    gap: var(--spacing-md);
    padding: var(--spacing-md);
    background: white;
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .info-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(12, 12, 12, 0.08);
  }

  .info-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-cream);
    border-radius: 4px;
    color: var(--color-accent);
  }

  .info-content h3 {
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
    font-family: var(--font-display);
  }

  .info-content p {
    color: rgba(12, 12, 12, 0.7);
    line-height: 1.8;
  }

  .info-content a {
    color: var(--color-accent);
    transition: color 0.3s ease;
  }

  .info-content a:hover {
    color: var(--color-text);
    text-decoration: underline;
  }

  .closed {
    font-style: italic;
    color: rgba(12, 12, 12, 0.5);
  }

  .social-links {
    padding: var(--spacing-md);
    background: white;
    border-radius: 4px;
  }

  .social-links h3 {
    font-size: 1.125rem;
    margin-bottom: var(--spacing-md);
    font-family: var(--font-display);
  }

  .social-icons {
    display: flex;
    gap: var(--spacing-sm);
  }

  .social-link {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-cream);
    border-radius: 4px;
    color: var(--color-accent);
    transition: all 0.3s ease;
  }

  .social-link:hover {
    background: var(--color-accent);
    color: white;
    transform: translateY(-4px);
  }

  .map-container {
    position: sticky;
    top: 100px;
    height: 500px;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(12, 12, 12, 0.1);
  }

  .map-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-cream) 0%, var(--color-background) 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-sm);
    color: var(--color-accent);
  }

  .map-placeholder p {
    font-size: 1.125rem;
    font-weight: 500;
  }

  .map-note {
    font-size: 0.875rem;
    color: rgba(12, 12, 12, 0.5);
    font-style: italic;
  }

  @media (max-width: 1024px) {
    .contatti-content {
      grid-template-columns: 1fr;
    }

    .map-container {
      position: relative;
      top: 0;
    }
  }

  @media (max-width: 768px) {
    .map-container {
      height: 300px;
    }
  }
</style>
