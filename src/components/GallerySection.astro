<style>
  .gallery-animate {
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 0.8s ease-out,
      transform 0.8s ease-out;
  }

  .gallery-animate.animated {
    opacity: 1;
    transform: translateY(0);
  }

  /* Gallery images stagger animation */
  .gallery-image {
    opacity: 0;
    transform: translateY(20px) scale(0.95);
    transition:
      opacity 0.6s ease-out,
      transform 0.6s ease-out;
  }

  .gallery-image.animated {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
</style>

<script>
  // Intersection Observer for scroll animations
  const observerOptions = {
    threshold: 0.1,
    rootMargin: "0px 0px -50px 0px",
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const element = entry.target as HTMLElement;
        const delay = element.dataset.delay || "0";

        setTimeout(() => {
          element.classList.add("animated");
        }, parseInt(delay));

        observer.unobserve(element);
      }
    });
  }, observerOptions);

  // Observe all elements with gallery-animate class
  document.querySelectorAll(".gallery-animate").forEach((el) => {
    observer.observe(el);
  });

  // Separate observer for gallery images with stagger effect
  const imageObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const element = entry.target as HTMLElement;
          const index = parseInt(element.dataset.index || "0");
          const staggerDelay = index * 80; // 80ms delay between each image

          setTimeout(() => {
            element.classList.add("animated");
          }, staggerDelay);

          imageObserver.unobserve(element);
        }
      });
    },
    {
      threshold: 0.1,
      rootMargin: "0px 0px -100px 0px",
    },
  );

  // Observe gallery images
  document.querySelectorAll(".gallery-image").forEach((el) => {
    imageObserver.observe(el);
  });
</script>
