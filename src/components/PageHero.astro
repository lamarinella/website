---
import Breadcrumbs from "./Breadcrumbs.astro";

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  titleAccent?: string;
  description: string;
  gradientFrom?: string;
  gradientTo?: string;
  backgroundImage?: string;
  backgroundVideo?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const {
  title,
  titleAccent,
  description,
  gradientFrom = "rgb(241,226,195)",
  gradientTo = "rgb(248,247,247)",
  backgroundImage,
  backgroundVideo,
  breadcrumbs,
} = Astro.props;
---

<section
  class="min-h-[60vh] flex items-center justify-center relative overflow-hidden pt-32 sm:pt-36 md:pt-40 pb-20 text-center"
  style={!backgroundImage && !backgroundVideo
    ? `background: linear-gradient(135deg, ${gradientFrom} 0%, ${gradientTo} 100%)`
    : ""}
>
  {
    backgroundVideo ? (
      /* Video Background with Overlay */
      <div class="absolute inset-0 w-full h-full">
        <video
          autoplay
          muted
          loop
          playsinline
          class="w-full h-full object-cover"
          preload="auto"
        >
          <source
            src={backgroundVideo}
            type={
              backgroundVideo.endsWith(".webm") ? "video/webm" : "video/mp4"
            }
          />
        </video>
        {/* Elegant Overlay for Text Visibility */}
        <div class="absolute inset-0 bg-linear-to-b from-[rgb(12,12,12)]/80 via-[rgb(12,12,12)]/45 to-[rgb(12,12,12)]/75" />
        <div class="absolute inset-0 bg-[rgb(12,12,12)]/20" />
      </div>
    ) : backgroundImage ? (
      /* Image Background with Overlay */
      <div class="absolute inset-0 w-full h-full">
        <img
          src={backgroundImage}
          alt=""
          class="w-full h-full object-cover object-center"
          loading="eager"
          fetchpriority="high"
        />
        {/* Elegant Overlay for Text Visibility */}
        <div class="absolute inset-0 bg-linear-to-b from-[rgb(12,12,12)]/80 via-[rgb(12,12,12)]/45 to-[rgb(12,12,12)]/75" />
        <div class="absolute inset-0 bg-[rgb(12,12,12)]/20" />
      </div>
    ) : (
      /* Pattern Background (fallback) */
      <div
        class="absolute inset-0 opacity-[0.03]"
        style="background-image: url('/brand assets/pattern chamoisee.svg'); background-size: 400px;"
      />
    )
  }

  <div class="max-w-4xl mx-auto px-6 md:px-8 lg:px-12 relative z-10">
    <!-- Breadcrumbs -->
    {
      breadcrumbs && breadcrumbs.length > 0 && (
        <div class="mb-8 flex justify-center opacity-0 animate-fade-in [animation-delay:100ms]">
          <Breadcrumbs
            items={breadcrumbs}
            light={!!backgroundImage || !!backgroundVideo}
          />
        </div>
      )
    }

    <!-- Title -->
    <h1
      class:list={[
        "mb-6 opacity-0 animate-fade-in-up [animation-delay:200ms]",
        backgroundImage || backgroundVideo ? "text-white drop-shadow-md" : "",
      ]}
    >
      {title}
      {
        titleAccent && (
          <>
            <br />
            <span
              class:list={[
                "italic block",
                backgroundImage || backgroundVideo
                  ? "text-[rgb(241,226,195)]"
                  : "text-accent",
              ]}
            >
              {titleAccent}
            </span>
          </>
        )
      }
    </h1>

    <!-- Description -->
    <p
      class:list={[
        "text-section-subtitle max-w-2xl mx-auto opacity-0 animate-fade-in-up [animation-delay:300ms]",
        backgroundImage || backgroundVideo
          ? "text-white/90 drop-shadow-sm"
          : "text-[rgb(12,12,12)]/65",
      ]}
    >
      {description}
    </p>
  </div>
</section>
