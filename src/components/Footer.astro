---
const currentYear = new Date().getFullYear();
---

<footer
  id="main-footer"
  class="bg-text text-background relative z-0 lg:fixed lg:bottom-0 lg:left-0 lg:w-full overflow-hidden pt-16 pb-6"
>
  <!-- Pattern Background -->
  <div
    class="absolute inset-0 opacity-[0.02] pointer-events-none"
    style="background-image: url('/brand assets/pattern chamoisee.svg'); background-size: 300px; background-repeat: repeat;"
  >
  </div>

  <div class="container-custom relative z-10">
    <!-- Main Footer Content -->
    <div
      class="grid lg:grid-cols-[1fr_3fr] gap-12 pb-12 mb-8 border-b border-background/10 text-center lg:text-left"
    >
      <!-- Brand Section -->
      <div class="flex flex-col gap-6 items-center lg:items-start">
        <img
          src="/brand assets/logo completo img.avif"
          alt="La Marinella"
          class="w-48 h-auto"
        />
        <p class="text-background/70 italic text-[0.9375rem] max-w-sm">
          Tradizione artigianale dal 2006. Produciamo ogni giorno gelato fresco
          e pasticceria di alta qualità con ingredienti selezionati.
        </p>
      </div>

      <!-- Links Grid -->
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Navigation -->
        <div>
          <h4
            class="text-lg mb-6 text-cream"
            style="font-family: var(--font-family-display)"
          >
            Navigazione
          </h4>
          <ul class="space-y-3">
            <li>
              <a
                href="/"
                class="text-background/70 hover:text-accent transition-colors text-[0.9375rem]"
                >Home</a
              >
            </li>
            <li>
              <a
                href="/pasticceria"
                class="text-background/70 hover:text-accent transition-colors text-[0.9375rem]"
                >Pasticceria</a
              >
            </li>
            <li>
              <a
                href="/gelateria"
                class="text-background/70 hover:text-accent transition-colors text-[0.9375rem]"
                >Gelateria</a
              >
            </li>
            <li>
              <a
                href="/menu"
                class="text-background/70 hover:text-accent transition-colors text-[0.9375rem]"
                >Menu</a
              >
            </li>
            <li>
              <a
                href="/contatti"
                class="text-background/70 hover:text-accent transition-colors text-[0.9375rem]"
                >Contatti</a
              >
            </li>
          </ul>
        </div>

        <!-- Contatti -->
        <div>
          <h4
            class="text-lg mb-6 text-cream"
            style="font-family: var(--font-family-display)"
          >
            Contatti
          </h4>
          <ul class="space-y-3 text-background/70 text-[0.9375rem]">
            <li>VIA SCALO FF.SS. SNC</li>
            <li>89868 Zambrone (VV)</li>
            <li>
              <a
                href="tel:+393456461131"
                class="hover:text-accent transition-colors">+39 345 646 1131</a
              >
            </li>
            <li>
              <a
                href="mailto:info@gelaterialamarinella.it"
                class="hover:text-accent transition-colors"
                >info@gelaterialamarinella.it</a
              >
            </li>
          </ul>
        </div>

        <!-- Orari -->
        <div>
          <h4
            class="text-lg mb-6 text-cream"
            style="font-family: var(--font-family-display)"
          >
            Orari
          </h4>
          <ul class="space-y-3 text-background/70 text-[0.9375rem]">
            <li>Tutti i giorni</li>
            <li>07:00 - 23:00</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom Footer -->
    <div
      class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-background/60"
    >
      <p>&copy; {currentYear} La Marinella. Tutti i diritti riservati.</p>
      <p class="flex flex-wrap items-center gap-2 justify-center">
        <span>P.IVA 02727080794</span>
        <span class="hidden md:inline">|</span>
        <a href="/privacy-policy" class="hover:text-accent transition-colors"
          >Privacy Policy</a
        >
        <span>|</span>
        <a href="/cookie-policy" class="hover:text-accent transition-colors"
          >Cookie Policy</a
        >
      </p>
    </div>
  </div>
</footer>

<script>
  function updateFooterHeight() {
    const footer = document.getElementById("main-footer");
    if (footer) {
      // Check if footer is position: fixed (desktop)
      const isFixed = window.getComputedStyle(footer).position === "fixed";

      if (isFixed) {
        const height = footer.offsetHeight;
        document.body.style.paddingBottom = `${height}px`;
      } else {
        document.body.style.paddingBottom = "0px";
      }
    }
  }

  // Update on load
  updateFooterHeight();

  // Update on resize
  window.addEventListener("resize", updateFooterHeight);

  // Update on astro page load (view transitions)
  document.addEventListener("astro:page-load", updateFooterHeight);
</script>
