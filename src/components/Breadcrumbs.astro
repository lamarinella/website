---
import { ChevronRight } from 'lucide-react';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  light?: boolean; // Use light colors (for dark backgrounds)
}

const { items, light = false } = Astro.props;
---

<nav aria-label="Breadcrumb" class="opacity-0 animate-fade-in [animation-delay:50ms]">
  <ol class="flex items-center gap-2 flex-wrap text-[0.8125rem] sm:text-sm tracking-wide">
    <!-- Home Link -->
    <li>
      <a 
        href="/" 
        class:list={[
          "transition-colors duration-300 hover:text-accent flex items-center gap-1",
          light ? "text-white/70 hover:text-cream" : "text-text/60"
        ]}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        <span class="sr-only sm:not-sr-only">Home</span>
      </a>
    </li>
    
    {items.map((item, index) => (
      <>
        <!-- Separator -->
        <li aria-hidden="true" class:list={[light ? "text-white/40" : "text-text/30"]}>
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/>
          </svg>
        </li>
        
        <!-- Breadcrumb Item -->
        <li>
          {item.href && index !== items.length - 1 ? (
            <a 
              href={item.href}
              class:list={[
                "transition-colors duration-300 hover:text-accent",
                light ? "text-white/70 hover:text-cream" : "text-text/60"
              ]}
            >
              {item.label}
            </a>
          ) : (
            <span 
              class:list={[
                "font-medium",
                light ? "text-cream" : "text-accent"
              ]}
              aria-current="page"
            >
              {item.label}
            </span>
          )}
        </li>
      </>
    ))}
  </ol>
</nav>
