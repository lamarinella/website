---
interface Props {
    lang: "it" | "en";
    forceDarkText?: boolean;
}

const { lang, forceDarkText = false } = Astro.props;

// Determine language toggle link
const targetLink = lang === "it" ? "/en/menu" : "/menu";
const targetLabel = lang === "it" ? "EN" : "IT";
const currentFlag = lang === "it" ? "🇮🇹" : "🇬🇧";
const targetFlag = lang === "it" ? "🇬🇧" : "🇮🇹";

// Initial Text Color Classes
const initialTextClass = forceDarkText
    ? "text-text/80 hover:text-text"
    : "text-white/80 hover:text-white";
const initialBorderClass = forceDarkText
    ? "border-text/20 hover:border-text/50"
    : "border-white/20 hover:border-white/50";
const initialLogo = forceDarkText
    ? "/brand assets/Logotipo black.svg"
    : "/brand assets/Logotipo Duch White.svg";
---

<nav
    id="menu-navbar"
    class="fixed top-0 left-0 right-0 z-1001 transition-transform duration-500 bg-transparent"
    data-force-dark={forceDarkText ? "true" : "false"}
>
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12 py-4 md:py-6">
        <div class="flex justify-between items-center">
            <!-- Logo -->
            <a
                href="/"
                class="h-5 md:h-7 transition-all duration-500 hover:opacity-60 z-10"
            >
                <img
                    id="menu-logo"
                    src={initialLogo}
                    alt="La Marinella"
                    class="h-full w-auto transition-all duration-500 logo-img-theme"
                />
            </a>

            <!-- Right Controls -->
            <div class="flex items-center gap-3 md:gap-4 z-10">
                <!-- Theme Toggle -->
                <button
                    type="button"
                    id="theme-toggle"
                    class={`w-9 h-9 transition-colors border bg-transparent cursor-pointer flex items-center justify-center rounded-none ${initialTextClass} ${initialBorderClass}`}
                    aria-label="Modalità"
                >
                    <svg
                        id="theme-toggle-dark-icon"
                        class="w-4 h-4 hidden fill-current"
                        viewBox="0 0 20 20"
                        xmlns="http://www.w3.org/2000/svg"
                        ><path
                            d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
                        ></path></svg
                    >
                    <svg
                        id="theme-toggle-light-icon"
                        class="w-4 h-4 hidden fill-current"
                        viewBox="0 0 20 20"
                        xmlns="http://www.w3.org/2000/svg"
                        ><path
                            d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4.22 3.22a1 1 0 011.415 0l.708.707a1 1 0 01-1.414 1.414l-.708-.707a1 1 0 010-1.414zM18 10a1 1 0 01-1 1h-1a1 1 0 110-2h1a1 1 0 011 1zM15.657 14.243a1 1 0 010 1.414l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 0zM10 18a1 1 0 01-1-1v-1a1 1 0 112 0v1a1 1 0 01-1 1zm-4.22-3.22a1 1 0 01-1.415 0l-.708-.707a1 1 0 011.414-1.414l.708.707a1 1 0 010 1.414zM2 10a1 1 0 011-1h1a1 1 0 110 2H3a1 1 0 01-1-1zm3.343-5.757a1 1 0 010-1.414l.707-.707a1 1 0 011.414 1.414l-.707.707a1 1 0 01-1.414 0zM10 6a4 4 0 100 8 4 4 0 000-8z"
                            fill-rule="evenodd"
                            clip-rule="evenodd"></path></svg
                    >
                </button>

                <!-- Language Dropdown -->
                <div class="relative" id="lang-dropdown-container">
                    <button
                        type="button"
                        id="lang-dropdown-btn"
                        class={`flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium tracking-[0.15em] uppercase transition-colors border rounded-none bg-transparent cursor-pointer ${initialTextClass} ${initialBorderClass}`}
                        aria-label="Scegli lingua"
                        aria-expanded="false"
                    >
                        <span>{lang === "it" ? "IT" : "EN"}</span>
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 512 512"
                            class="h-3 w-3 opacity-70 fill-current"
                        >
                            <path
                                d="M233.4 406.6c12.5 12.5 32.8 12.5 45.3 0l192-192c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L256 338.7 86.6 169.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l192 192z"
                            ></path>
                        </svg>
                    </button>

                    <!-- Dropdown Menu -->
                    <div
                        id="lang-dropdown-menu"
                        class="absolute right-0 top-full mt-2 w-48 bg-(--color-card-bg)/95 backdrop-blur-md shadow-xl rounded-none border border-(--color-card-border) opacity-0 invisible transform origin-top-right transition-all duration-200 translate-y-2 z-50 text-text"
                    >
                        <ul class="py-2">
                            <li>
                                <a
                                    href="/menu"
                                    class={`flex items-center gap-3 px-4 py-3 hover:bg-black/5 dark:hover:bg-white/5 transition-colors rounded-none ${lang === "it" ? "text-accent bg-accent/5" : ""}`}
                                >
                                    <span class="text-xl">🇮🇹</span>
                                    <span
                                        class="text-sm font-medium tracking-wide"
                                        >Italiano</span
                                    >
                                    {
                                        lang === "it" && (
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                viewBox="0 0 448 512"
                                                class="ml-auto h-3 w-3 fill-current"
                                            >
                                                <path d="M438.6 105.4c12.5 12.5 12.5 32.8 0 45.3l-256 256c-12.5 12.5-32.8 12.5-45.3 0l-128-128c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0L160 338.7 393.4 105.4c12.5-12.5 32.8-12.5 45.3 0z" />
                                            </svg>
                                        )
                                    }
                                </a>
                            </li>
                            <li>
                                <a
                                    href="/en/menu"
                                    class={`flex items-center gap-3 px-4 py-3 hover:bg-black/5 dark:hover:bg-white/5 transition-colors rounded-none ${lang === "en" ? "text-accent bg-accent/5" : ""}`}
                                >
                                    <span class="text-xl">🇬🇧</span>
                                    <span
                                        class="text-sm font-medium tracking-wide"
                                        >English</span
                                    >
                                    {
                                        lang === "en" && (
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                viewBox="0 0 448 512"
                                                class="ml-auto h-3 w-3 fill-current"
                                            >
                                                <path d="M438.6 105.4c12.5 12.5 12.5 32.8 0 45.3l-256 256c-12.5 12.5-32.8 12.5-45.3 0l-128-128c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0L160 338.7 393.4 105.4c12.5-12.5 32.8-12.5 45.3 0z" />
                                            </svg>
                                        )
                                    }
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</nav>

<script>
    function initMenuNavbar() {
        const navbar = document.getElementById("menu-navbar");
        const logo = document.getElementById("menu-logo");
        // Dropdown elements
        const dropdownContainer = document.getElementById(
            "lang-dropdown-container",
        );
        const dropdownBtn = document.getElementById("lang-dropdown-btn");
        const dropdownMenu = document.getElementById("lang-dropdown-menu");

        // Theme Toggle elements
        const themeToggleBtn = document.getElementById("theme-toggle");
        const darkIcon = document.getElementById("theme-toggle-dark-icon");
        const lightIcon = document.getElementById("theme-toggle-light-icon");

        if (!navbar || !logo) return;

        const forceDark = navbar.dataset.forceDark === "true";

        let lastScrollY = window.scrollY;

        // ----- THEME LOGIC -----
        // Change the icons inside the button based on previous settings
        function updateThemeIcons() {
            if (!darkIcon || !lightIcon) return;
            if (document.documentElement.classList.contains("dark")) {
                darkIcon.classList.remove("hidden");
                lightIcon.classList.add("hidden");
            } else {
                lightIcon.classList.remove("hidden");
                darkIcon.classList.add("hidden");
            }
        }

        // Initial setup
        updateThemeIcons();

        if (themeToggleBtn) {
            themeToggleBtn.addEventListener("click", function () {
                // toggle inside html
                document.documentElement.classList.toggle("dark");
                // if set to dark, set localstorage and toggle icons
                if (document.documentElement.classList.contains("dark")) {
                    localStorage.setItem("theme", "dark");
                } else {
                    localStorage.setItem("theme", "light");
                }
                updateThemeIcons();
                updateLogoBasedOnTheme(); // Also update logo if necessary
            });
        }

        // ----- NAVBAR LOGIC -----
        function updateLogoBasedOnTheme() {
            if (!logo) return;
            const isDark = document.documentElement.classList.contains("dark");

            // In dark mode, Logo is ALWAYS white.
            // In light mode, it's black.
            logo.setAttribute(
                "src",
                isDark
                    ? "/brand assets/Logotipo Duch White.svg"
                    : "/brand assets/Logotipo black.svg",
            );
        }

        const updateNavbar = () => {
            const currentScrollY = window.scrollY;
            const scrolled = currentScrollY > 10;
            const isDark = document.documentElement.classList.contains("dark");

            // Close dropdown if open when scrolling
            if (
                scrolled &&
                dropdownMenu &&
                !dropdownMenu.classList.contains("invisible")
            ) {
                toggleDropdown(false);
            }

            // Style changes based on scroll position
            if (scrolled) {
                navbar.classList.add(
                    "bg-(--color-menu-container)", // updated to match menu container background
                    "backdrop-blur-xl",
                    "shadow-sm",
                    "border-b",
                    "border-(--color-card-border)",
                );
                navbar.classList.remove("bg-transparent");
            } else {
                navbar.classList.remove(
                    "bg-(--color-menu-container)",
                    "backdrop-blur-xl",
                    "shadow-sm",
                    "border-b",
                    "border-(--color-card-border)",
                );
                navbar.classList.add("bg-transparent");
            }

            updateLogoBasedOnTheme();

            // Handle Text Color based on Dark mode (ignoring forceDark logic now since background is solid)
            const controls = [dropdownBtn, themeToggleBtn];

            if (isDark) {
                // Dark mode: white text/borders
                controls.forEach((ctrl) => {
                    if (ctrl) {
                        ctrl.classList.remove(
                            "text-text/80",
                            "hover:text-text",
                            "border-text/20",
                            "hover:border-text/50",
                        );
                        ctrl.classList.add(
                            "text-white/80",
                            "hover:text-white",
                            "border-white/20",
                            "hover:border-white/50",
                        );
                    }
                });
            } else {
                // Light mode: dark text/borders
                controls.forEach((ctrl) => {
                    if (ctrl) {
                        ctrl.classList.remove(
                            "text-white/80",
                            "hover:text-white",
                            "border-white/20",
                            "hover:border-white/50",
                        );
                        ctrl.classList.add(
                            "text-text/80",
                            "hover:text-text",
                            "border-text/20",
                            "hover:border-text/50",
                        );
                    }
                });
            }

            lastScrollY = currentScrollY;
        };

        updateNavbar();
        window.addEventListener("scroll", updateNavbar, { passive: true });

        // Dropdown Logic
        /** @param {boolean} show */
        function toggleDropdown(show: boolean) {
            if (!dropdownMenu || !dropdownBtn) return;

            if (show) {
                dropdownMenu.classList.remove(
                    "invisible",
                    "opacity-0",
                    "translate-y-2",
                );
                dropdownBtn.setAttribute("aria-expanded", "true");
            } else {
                dropdownMenu.classList.add(
                    "invisible",
                    "opacity-0",
                    "translate-y-2",
                );
                dropdownBtn.setAttribute("aria-expanded", "false");
            }
        }

        if (dropdownBtn && dropdownMenu) {
            dropdownBtn.addEventListener("click", (e) => {
                e.stopPropagation();
                // Safe to check classList because we checked existence above
                const isHidden = dropdownMenu.classList.contains("invisible");
                toggleDropdown(isHidden);
            });
        }

        // Close on click outside
        document.addEventListener("click", (e) => {
            if (
                dropdownContainer &&
                !dropdownContainer.contains(e.target as Node)
            ) {
                toggleDropdown(false);
            }
        });

        // Close on escape
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape") toggleDropdown(false);
        });

        // Ensure logo handles theme changes correctly even without scrolling
        const themeObserver = new MutationObserver(() => updateNavbar());
        themeObserver.observe(document.documentElement, {
            attributes: true,
            attributeFilter: ["class"],
        });
    }

    document.addEventListener("astro:page-load", initMenuNavbar);
    if (document.readyState !== "loading") {
        initMenuNavbar();
    } else {
        document.addEventListener("DOMContentLoaded", initMenuNavbar);
    }
</script>
