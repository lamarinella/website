---
import { Image } from "astro:assets";
import heroImage from "../assets/hero-image.avif";
---

<section class="relative min-h-screen w-full overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0 w-full h-full">
    <Image
      src={heroImage}
      alt="La Marinella"
      class="w-full h-full object-cover object-center"
      fetchpriority="high"
      loading="eager"
      widths={[640, 768, 1024, 1280, 1536, 1920]}
      sizes="100vw"
    />
    <!-- Elegant Overlay for Text Visibility -->
    <div
      class="absolute inset-0 bg-linear-to-b from-[rgb(12,12,12)]/80 via-[rgb(12,12,12)]/45 to-[rgb(12,12,12)]/75"
    >
    </div>
    <div class="absolute inset-0 bg-[rgb(12,12,12)]/20"></div>
  </div>

  <!-- Content -->
  <div
    class="relative h-full min-h-screen flex items-center justify-center text-center z-10 px-6 hero-safe-top hero-safe-bottom"
  >
    <div class="max-w-6xl mx-auto space-y-6 sm:space-y-8 md:space-y-10">
      <!-- Hero Title -->
      <div
        class="space-y-2 opacity-0 animate-fade-in-up [animation-delay:200ms]"
      >
        <h1
          class="text-white leading-[0.9] drop-shadow-[0_2px_10px_rgba(0,0,0,0.3)] text-[3.75rem] sm:text-[4.5rem] md:text-[5.5rem] lg:text-[6.5rem] xl:text-[7.5rem]"
        >
          <span class="block font-light">L'Eccellenza</span>
          <span class="italic text-[rgb(241,226,195)] block font-normal"
            >Artigianale</span
          >
        </h1>
      </div>

      <!-- Refined Subtitle -->
      <p
        class="text-[1.125rem] sm:text-[1.25rem] md:text-[1.375rem] lg:text-[1.5rem] font-light tracking-wide leading-[1.6] text-white/95 max-w-3xl mx-auto drop-shadow-[0_2px_8px_rgba(0,0,0,0.4)]"
      >
        Gelateria e Pasticceria Artigianale a Zambrone Marina.<br
          class="hidden sm:block"
        />
        Dal 2006, creiamo esperienze di gusto uniche unendo tradizione e materie prime
        d'eccellenza.
      </p>

      <!-- CTA Buttons with optimal spacing -->
      <div
        class="flex flex-col sm:flex-row gap-4 justify-center pt-4 opacity-0 animate-fade-in-up [animation-delay:500ms]"
      >
        <a href="/menu" class="btn-hero btn-hero-primary group">
          <span>Scopri il menù</span>
          <svg
            width="16"
            height="16"
            viewBox="0 0 20 20"
            fill="none"
            class="transition-transform duration-300 group-hover:translate-x-1"
          >
            <path
              d="M4 10H16M16 10L11 5M16 10L11 15"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
        <a
          href="https://maps.app.goo.gl/Pjqm3MaSimh7MvWn7"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-hero btn-hero-secondary"
        >
          <span>Dove trovarci</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .btn-hero {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    padding: 0.875rem 2rem;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid transparent;
    white-space: nowrap;
  }

  .btn-hero-primary {
    background: white;
    color: rgb(12, 12, 12);
  }

  .btn-hero-primary:hover {
    background: rgb(241, 226, 195);
    transform: translateY(-2px);
    box-shadow: 0 15px 35px rgba(255, 255, 255, 0.12);
  }

  .btn-hero-secondary {
    background: transparent;
    border-color: white;
    color: white;
  }

  .btn-hero-secondary:hover {
    background: white;
    color: rgb(12, 12, 12);
    transform: translateY(-2px);
    box-shadow: 0 15px 35px rgba(255, 255, 255, 0.12);
  }

  @media (min-width: 1024px) {
    .btn-hero {
      padding: 1rem 2.5rem;
      font-size: 0.8125rem;
    }
  }

  @media (max-width: 640px) {
    .btn-hero {
      width: 100%;
      padding: 1rem 1.75rem;
    }
  }
</style>
