---
import MenuLayout from "../layouts/MenuLayout.astro";
import MenuNavbar from "../components/MenuNavbar.astro";
import menuData from "../data/menu.json";
import MenuGrid from "../components/MenuGrid.astro";

const menuCategories = menuData.categories as any[];

// Estrae i gusti per categoria e li passa al client via script inline
const flavorsMap: Record<string, any[]> = {};
for (const cat of menuCategories) {
    if (cat.flavors) flavorsMap[cat.id] = cat.flavors;
}
---

<MenuLayout
  title="Menu | La Marinella"
  description="Il menu completo de La Marinella: caffetteria, dolci, panini, birre, cocktails, vini, distillati, gelateria e rosticceria."
>
  <!-- Dati gusti gelato per il modal (accessibili da JS client-side) -->
  <script is:inline define:vars={{ flavorsMap }}>
    window.__menuFlavors = flavorsMap;
  </script>

  <MenuNavbar lang="it" forceDarkText={false} hideThemeToggle={true} />
  <MenuGrid menuCategories={menuCategories} lang="it" />
</MenuLayout>
