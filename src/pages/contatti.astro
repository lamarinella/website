---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navigation from "../components/Navigation.astro";
import PageHero from "../components/PageHero.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Contatti | La Marinella"
  description="Vieni a trovarci a Zambrone Marina. Scopri orari, indirizzo e come raggiungerci."
>
  <Navigation />

  <main>
    <PageHero
      title="Vieni a"
      titleAccent="Trovarci"
      description="Ti aspettiamo per farti assaporare le nostre specialità artigianali."
      backgroundImage="/images/zona tavolini-img.avif"
      breadcrumbs={[{ label: "Contatti" }]}
    />

    <!-- Main Contact Section -->
    <section class="py-24 md:py-32 bg-white">
      <div class="container-custom">
        <!-- Section Header -->
        <div class="text-center max-w-2xl mx-auto mb-20">
          <span
            class="text-accent text-xs font-medium tracking-[0.25em] uppercase mb-4 block"
          >
            Contatti
          </span>
          <h2 class="text-4xl md:text-5xl font-serif text-text mb-6">
            Siamo qui per te
          </h2>
          <p class="text-text/60 leading-relaxed">
            Un angolo di dolcezza nel cuore di Zambrone Marina. Vieni a scoprire
            dove nasce la magia del vero gelato artigianale.
          </p>
        </div>

        <!-- Contact Grid -->
        <div
          class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-5xl mx-auto mb-20"
        >
          <!-- Address -->
          <div class="text-center p-6">
            <div
              class="w-14 h-14 mx-auto mb-5 flex items-center justify-center rounded-full border border-accent/20"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1"
                class="text-accent"
              >
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <h3 class="font-serif text-lg text-text mb-2">Indirizzo</h3>
            <p class="text-text/60 text-sm leading-relaxed">
              Via Scalo FF.SS. snc<br />
              89868 Zambrone (VV)
            </p>
          </div>

          <!-- Hours -->
          <div class="text-center p-6">
            <div
              class="w-14 h-14 mx-auto mb-5 flex items-center justify-center rounded-full border border-accent/20"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1"
                class="text-accent"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <h3 class="font-serif text-lg text-text mb-2">Orari</h3>
            <p class="text-text/60 text-sm leading-relaxed">
              Tutti i giorni<br />
              <span class="font-medium text-text">07:00 – 23:00</span>
            </p>
          </div>

          <!-- Phone -->
          <div class="text-center p-6">
            <div
              class="w-14 h-14 mx-auto mb-5 flex items-center justify-center rounded-full border border-accent/20"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1"
                class="text-accent"
              >
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                ></path>
              </svg>
            </div>
            <h3 class="font-serif text-lg text-text mb-2">Telefono</h3>
            <a
              href="tel:+393456461131"
              class="text-text/60 text-sm hover:text-accent transition-colors"
            >
              +39 345 646 1131
            </a>
          </div>

          <!-- Season -->
          <div class="text-center p-6">
            <div
              class="w-14 h-14 mx-auto mb-5 flex items-center justify-center rounded-full border border-accent/20"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1"
                class="text-accent"
              >
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
            </div>
            <h3 class="font-serif text-lg text-text mb-2">Stagione</h3>
            <p class="text-text/60 text-sm leading-relaxed">Marzo – Ottobre</p>
          </div>
        </div>

        <!-- Map Section -->
        <div class="max-w-5xl mx-auto">
          <a
            href="https://maps.app.goo.gl/Pjqm3MaSimh7MvWn7"
            target="_blank"
            rel="noopener noreferrer"
            class="block relative group overflow-hidden rounded-lg shadow-xl"
          >
            <img
              src="/brand assets/la-marinella-maps.avif"
              alt="Mappa La Marinella Zambrone"
              class="w-full h-[400px] md:h-[500px] object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <!-- Overlay -->
            <div
              class="absolute inset-0 bg-black/20 group-hover:bg-black/30 transition-colors duration-300"
            >
            </div>

            <!-- CTA Badge -->
            <div
              class="absolute bottom-6 left-6 right-6 md:left-auto md:right-6 md:w-auto"
            >
              <div
                class="bg-white px-6 py-4 shadow-lg flex items-center gap-4 group-hover:-translate-y-1 transition-transform duration-300"
              >
                <div>
                  <p class="font-serif text-lg text-text">
                    Apri in Google Maps
                  </p>
                  <p class="text-xs text-text/50 uppercase tracking-widest">
                    Ottieni indicazioni
                  </p>
                </div>
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  class="text-accent -rotate-45 group-hover:rotate-0 transition-transform duration-300"
                >
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- How to Reach Us -->
    <section class="py-24 bg-background">
      <div class="container-custom">
        <div class="text-center mb-16">
          <span
            class="text-accent text-xs font-medium tracking-[0.25em] uppercase mb-4 block"
          >
            Indicazioni
          </span>
          <h2 class="text-3xl md:text-4xl font-serif text-text">
            Come Raggiungerci
          </h2>
        </div>

        <div class="grid md:grid-cols-3 gap-10 max-w-5xl mx-auto">
          <!-- Car -->
          <div
            class="text-center p-8 bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow"
          >
            <div
              class="w-16 h-16 mx-auto mb-6 flex items-center justify-center rounded-full bg-accent/10"
            >
              <svg
                width="28"
                height="28"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1"
                class="text-accent"
              >
                <path
                  d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"
                ></path>
                <circle cx="7" cy="17" r="2"></circle>
                <circle cx="17" cy="17" r="2"></circle>
              </svg>
            </div>
            <h3 class="font-serif text-xl text-text mb-3">In Auto</h3>
            <p class="text-text/60 text-sm leading-relaxed">
              Dalla SS18, segui le indicazioni per Zambrone Marina. Siamo vicino
              alla stazione ferroviaria.
            </p>
          </div>

          <!-- Train -->
          <div
            class="text-center p-8 bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow"
          >
            <div
              class="w-16 h-16 mx-auto mb-6 flex items-center justify-center rounded-full bg-accent/10"
            >
              <svg
                width="28"
                height="28"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1"
                class="text-accent"
              >
                <rect x="4" y="3" width="16" height="16" rx="2"></rect>
                <path d="M4 11h16"></path>
                <path d="M12 3v8"></path>
                <circle cx="8" cy="15" r="1"></circle>
                <circle cx="16" cy="15" r="1"></circle>
                <path d="M8 19l-2 3"></path>
                <path d="M16 19l2 3"></path>
              </svg>
            </div>
            <h3 class="font-serif text-xl text-text mb-3">In Treno</h3>
            <p class="text-text/60 text-sm leading-relaxed">
              Fermata di Zambrone. Comodissimo un pit stop dolce.
            </p>
          </div>

          <!-- Walking -->
          <div
            class="text-center p-8 bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow"
          >
            <div
              class="w-16 h-16 mx-auto mb-6 flex items-center justify-center rounded-full bg-accent/10"
            >
              <svg
                width="28"
                height="28"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1"
                class="text-accent"
              >
                <circle cx="12" cy="5" r="2"></circle>
                <path d="M10 22l4-12"></path>
                <path d="M5 12l5-2 3 5"></path>
                <path d="M17 18l-3-8"></path>
              </svg>
            </div>
            <h3 class="font-serif text-xl text-text mb-3">A Piedi</h3>
            <p class="text-text/60 text-sm leading-relaxed">
              Raggiungibile dalla spiaggia Paradiso del Sub e dalle strutture
              ricettive della zona.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Social & Follow -->
    <section class="py-20 bg-cream/30">
      <div class="container-custom text-center">
        <span
          class="text-accent text-xs font-medium tracking-[0.25em] uppercase mb-4 block"
        >
          Resta Connesso
        </span>
        <h2 class="text-2xl md:text-3xl font-serif text-text mb-8">
          Seguici sui Social
        </h2>
        <p class="text-text/60 text-sm mb-10 max-w-md mx-auto">
          Rimani aggiornato sulle nostre novità, gusti stagionali e promozioni
          speciali.
        </p>
        <div class="flex justify-center gap-6">
          <a
            href="https://www.facebook.com/GelateriaLaMarinella"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col items-center gap-3 px-6 py-4 bg-white rounded-lg shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1"
          >
            <div
              class="w-12 h-12 flex items-center justify-center rounded-full bg-accent/10 text-accent group-hover:bg-accent group-hover:text-white transition-colors"
            >
              <svg
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                ></path>
              </svg>
            </div>
            <span
              class="text-xs uppercase tracking-widest text-text/60 group-hover:text-accent transition-colors"
              >Facebook</span
            >
          </a>
          <a
            href="https://www.instagram.com/gelateria_lamarinella/"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col items-center gap-3 px-6 py-4 bg-white rounded-lg shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1"
          >
            <div
              class="w-12 h-12 flex items-center justify-center rounded-full bg-accent/10 text-accent group-hover:bg-accent group-hover:text-white transition-colors"
            >
              <svg
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                ></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
            </div>
            <span
              class="text-xs uppercase tracking-widest text-text/60 group-hover:text-accent transition-colors"
              >Instagram</span
            >
          </a>
        </div>
      </div>
    </section>

    <!-- Legal Info (Minimal) -->
    <section class="py-10 bg-background border-t border-black/5">
      <div class="container-custom">
        <details class="text-center">
          <summary
            class="text-xs uppercase tracking-[0.15em] text-text/30 cursor-pointer hover:text-text/50 transition-colors inline-flex items-center gap-2"
          >
            Dati Societari
            <svg
              width="10"
              height="10"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="transition-transform duration-300"
            >
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </summary>
          <div
            class="mt-8 text-xs text-text/50 flex flex-col items-center gap-1.5 max-w-2xl mx-auto"
          >
            <p class="font-medium text-text/90">
              La Marinella di Giannini Romana & C. s.a.s.
            </p>
            <p class="text-sm">Via Antonio Gramsci snc, 89868 Zambrone (VV)</p>
            <div
              class="flex flex-wrap justify-center gap-x-3 gap-y-1 opacity-80"
            >
              <span>P.IVA 02727080794</span>
              <span class="hidden sm:inline">•</span>
              <span>REA VV-160841</span>
              <span class="hidden sm:inline">•</span>
              <span>PEC: lamarinellasas@pec.it</span>
            </div>
          </div>
        </details>
        <style>
          details[open] summary svg {
            transform: rotate(180deg);
          }
        </style>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
