---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MenuNavbar from "../../components/MenuNavbar.astro";
import menuData from "../../data/menu.json";
import MenuGrid from "../../components/MenuGrid.astro";

const menuCategories = menuData.categories as any[];
---

<BaseLayout
  title="Menu | La Marinella"
  description="Our complete menu: gelato, cafeteria, hot foods, and aperitifs."
  lang="en"
>
  <MenuNavbar lang="en" forceDarkText={true} />

  <MenuGrid menuCategories={menuCategories} lang="en" />
</BaseLayout>
