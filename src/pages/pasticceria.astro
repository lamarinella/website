---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navigation from "../components/Navigation.astro";
import PageHero from "../components/PageHero.astro";
import Footer from "../components/Footer.astro";
import AnimationObserver from "../components/AnimationObserver.astro";
import ImageSlideshow from "../components/ImageSlideshow.astro";
---

<BaseLayout
  title="Pasticceria | La Marinella"
  description="Scopri la nostra pasticceria artigianale: dolci freschi, biscotti tradizionali e specialità preparate ogni giorno con ingredienti selezionati."
>
  <Navigation />

  <main>
    <PageHero
      title="L'Arte della"
      titleAccent="Dolcezza"
      description="Ogni dolce racconta una storia di tradizione, dedizione ed eccellenza."
      backgroundVideo="/videos/optimized/pasticceria-hero.webm"
      breadcrumbs={[{ label: "Pasticceria" }]}
    />

    <!-- Intro Section -->
    <section class="section-padding bg-white">
      <div class="container-custom">
        <div
          class="max-w-4xl mx-auto text-center mb-16 lg:mb-24"
          data-stagger-container
        >
          <span
            class="text-accent text-sm uppercase tracking-[0.2em] mb-4 block reveal-on-scroll opacity-0"
            data-animation="animate-fade-in-up">Eccellenza Quotidiana</span
          >
          <h2
            class="text-4xl md:text-5xl lg:text-6xl font-serif mb-8 reveal-on-scroll opacity-0"
            data-animation="animate-fade-in-up"
          >
            La Tradizione <span class="italic text-accent">Artigianale</span>
          </h2>
          <p
            class="text-lg md:text-xl text-[rgb(12,12,12)]/70 leading-relaxed font-light reveal-on-scroll opacity-0"
            data-animation="animate-fade-in-up"
          >
            Nei nostri laboratori di pasticceria seguiamo antiche ricette e
            tecniche artigianali, selezionando con cura ogni ingrediente. Dalla
            farina alla frutta fresca, ogni dettaglio è pensato per offrirti il
            massimo della genuinità e del gusto.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
          <div
            class="relative group overflow-hidden rounded-sm shadow-xl aspect-4/5 md:aspect-auto md:h-[600px] reveal-on-scroll opacity-0"
            data-animation="animate-fade-in"
          >
            <img
              src="/images/pasticceria-img.avif"
              alt="Mani sapienti al lavoro"
              class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
            />
          </div>
          <div class="flex flex-col gap-8 md:gap-12" data-stagger-container>
            <div
              class="flex gap-6 items-start group reveal-on-scroll opacity-0"
            >
              <div
                class="shrink-0 flex items-center justify-center w-16 h-16 rounded-full bg-[rgb(250,248,245)] text-accent transition-colors duration-500 group-hover:bg-accent group-hover:text-white"
              >
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  class="transition-transform duration-500 group-hover:scale-110"
                >
                  <path
                    d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                    fill="currentColor"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-2xl font-serif mb-3">Passione</h3>
                <p class="text-[rgb(12,12,12)]/70 leading-relaxed">
                  Non è solo lavoro, è il desiderio di regalare un'emozione
                  dolce a chi assaggia le nostre creazioni.
                </p>
              </div>
            </div>

            <div
              class="flex gap-6 items-start group reveal-on-scroll opacity-0"
            >
              <div
                class="shrink-0 flex items-center justify-center w-16 h-16 rounded-full bg-[rgb(250,248,245)] text-accent transition-colors duration-500 group-hover:bg-accent group-hover:text-white"
              >
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M17 3H7c-1.1 0-1.99.9-1.99 2L5 21l7-3 7 3V5c0-1.1-.9-2-2-2z"
                    stroke="currentColor"
                    stroke-width="0.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-2xl font-serif mb-3">Qualità</h3>
                <p class="text-[rgb(12,12,12)]/70 leading-relaxed">
                  Utilizziamo solo materie prime di altissima qualità. Latte
                  fresco, uova da allevamenti controllati, burro pregiato e
                  frutta di stagione. Nessun compromesso sulla qualità.
                </p>
              </div>
            </div>

            <div
              class="flex gap-6 items-start group reveal-on-scroll opacity-0"
            >
              <div
                class="shrink-0 flex items-center justify-center w-16 h-16 rounded-full bg-[rgb(250,248,245)] text-accent transition-colors duration-500 group-hover:bg-accent group-hover:text-white"
              >
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="0.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <circle cx="12" cy="12" r="10"></circle>
                  <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
              </div>
              <div>
                <h3 class="text-2xl font-serif mb-3">Freschezza</h3>
                <p class="text-[rgb(12,12,12)]/70 leading-relaxed">
                  Sforniamo le nostre delizie quotidianamente. La freschezza è
                  il segreto della nostra bontà, per garantire un'esperienza di
                  gusto sempre perfetta.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Event Cakes Section -->
    <!-- Event Cakes Section -->
    <section
      class="section-padding bg-accent relative overflow-hidden text-white"
    >
      <!-- Background Decorations -->
      <div
        class="absolute top-0 right-0 w-1/3 h-full bg-white/10 -skew-x-12 transform translate-x-32 pointer-events-none"
      >
      </div>

      <div class="container-custom relative">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div class="order-2 lg:order-1 reveal-on-scroll opacity-0">
            <span
              class="text-cream text-xs uppercase tracking-[0.2em] mb-4 block"
              >Momenti Speciali</span
            >
            <h2
              class="text-4xl md:text-5xl lg:text-6xl font-serif mb-8 text-white"
            >
              Torte per <span class="italic text-cream">Ogni Occasione</span>
            </h2>
            <p class="text-white/80 leading-relaxed text-lg mb-8">
              Nel nostro laboratorio artigianale diamo forma ai tuoi desideri.
              Che sia un compleanno, un matrimonio, una laurea o un battesimo,
              creiamo torte su misura che sono vere opere d'arte.
            </p>

            <ul class="space-y-6 mb-10">
              <li class="flex items-start gap-4">
                <span class="text-cream mt-1">✦</span>
                <div>
                  <h4 class="font-serif text-xl mb-1 text-white">
                    Personalizzazione Totale
                  </h4>
                  <p class="text-white/70 text-sm">
                    Scegli gusto, farcitura, forma, colore e decorazioni.
                    Realizziamo anche torte in pasta di zucchero (cake design).
                  </p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span class="text-cream mt-1">✦</span>
                <div>
                  <h4 class="font-serif text-xl mb-1 text-white">
                    Solo su Ordinazione
                  </h4>
                  <p class="text-white/70 text-sm">
                    Per garantirti la massima freschezza e cura dei dettagli,
                    realizziamo le torte evento esclusivamente su prenotazione.
                  </p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span class="text-cream mt-1">✦</span>
                <div>
                  <h4 class="font-serif text-xl mb-1 text-white">
                    Stile Unico
                  </h4>
                  <p class="text-white/70 text-sm">
                    Dalle classiche millefoglie al pan di spagna, ogni torta è
                    unica e irripetibile.
                  </p>
                </div>
              </li>
            </ul>

            <div class="flex flex-wrap gap-4">
              <a
                href="tel:+393456461131"
                class="inline-flex items-center gap-2 px-8 py-4 bg-white text-accent text-sm uppercase tracking-widest hover:bg-cream hover:text-accent transition-all duration-500 shadow-lg hover:shadow-xl hover:-translate-y-1"
              >
                Prenota la tua torta
              </a>
            </div>
          </div>

          <div
            class="order-1 lg:order-2 grid grid-cols-2 gap-4"
            data-stagger-container
          >
            <div class="space-y-4 mt-12">
              <div
                class="rounded-sm overflow-hidden shadow-lg aspect-3/4 reveal-on-scroll opacity-0"
                data-animation="animate-zoom-in"
              >
                <ImageSlideshow
                  images={[
                    "/images/torte/1.avif",
                    "/images/torte/2.avif",
                    "/images/torte/6.avif",
                  ]}
                  alt="Torta Evento"
                  interval={4000}
                />
              </div>
              <div
                class="rounded-sm overflow-hidden shadow-lg aspect-square reveal-on-scroll opacity-0"
                data-animation="animate-zoom-in"
              >
                <ImageSlideshow
                  images={["/images/torte/9.avif", "/images/torte/3.avif"]}
                  alt="Dettaglio Torta"
                  interval={5000}
                />
              </div>
            </div>
            <div class="space-y-4">
              <div
                class="rounded-sm overflow-hidden shadow-lg aspect-square reveal-on-scroll opacity-0"
                data-animation="animate-zoom-in"
              >
                <ImageSlideshow
                  images={["/images/torte/11.avif", "/images/torte/5.avif"]}
                  alt="Pasticceria Mignon"
                  interval={4500}
                />
              </div>
              <div
                class="rounded-sm overflow-hidden shadow-lg aspect-3/4 reveal-on-scroll opacity-0"
                data-animation="animate-zoom-in"
              >
                <ImageSlideshow
                  images={["/images/torte/8.avif", "/images/torte/4.avif"]}
                  alt="Buffet Dolci"
                  interval={5500}
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Visit Store CTA -->
    <section class="py-24 bg-white text-center reveal-on-scroll opacity-0">
      <div class="container-custom">
        <h2 class="text-4xl md:text-5xl font-serif mb-8">
          Voglia di Dolcezza?
        </h2>
        <p class="text-lg text-[rgb(12,12,12)]/70 max-w-2xl mx-auto mb-12">
          Da Aprile a Settembre potrai trovarci nel nostro punto vendita a
          Zambrone. Troverai ogni giorno un'ampia scelta di pasticceria fresca,
          mignon, monoporzioni e biscotti appena sfornati. Torte per eventi
          disponibili tutto l'anno su prenotazione!
        </p>
        <a
          href="https://maps.app.goo.gl/Pjqm3MaSimh7MvWn7"
          target="_blank"
          class="inline-block border-b border-accent pb-1 text-accent uppercase tracking-widest hover:text-[rgb(123,123,84)] hover:border-[rgb(123,123,84)] transition-all"
        >
          Ottieni indicazioni stradali
        </a>
      </div>
      <a
        href="tel:+393456461131"
        class="inline-flex items-center mt-6 px-8 py-4 bg-accent text-white text-sm uppercase tracking-widest hover:bg-cream hover:text-accent transition-all duration-500 shadow-lg hover:shadow-xl hover:-translate-y-1"
      >
        Chiama ora
      </a>
    </section>
  </main>

  <Footer />
  <AnimationObserver />
</BaseLayout>
